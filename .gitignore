# Environment files — never track. Templates (.example, .sample, .template)
# are explicitly allowed back so dot_env.example stays trackable.

# Literal .env at any depth
.env
.env.*
!.env.example
!.env.sample
!.env.template

# chezmoi source names (dot_env → ~/.env on apply)
dot_env
dot_env.*
!dot_env.example
!dot_env.sample
!dot_env.template

# Runtime artefacts — playwright-mcp / chrome-devtools-mcp dump session
# console logs in CWD when invoked from this repo. Not config; ignore.
.playwright-mcp/

# Python bytecode caches (slugify-title.py et al.).
__pycache__/
*.pyc
