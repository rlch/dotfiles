#!/usr/bin/env bash
# Install cargo subcommands that aren't on Homebrew. Reruns whenever the
# Brewfile hash changes (so additions to the cargo block stay in sync).
#
# Brewfile hash: {{ include "Brewfile" | sha256sum }}

set -euo pipefail

if ! command -v cargo >/dev/null 2>&1; then
  echo "cargo-tools: cargo not on PATH — run 'rustup default stable' first; skipping"
  exit 0
fi

# `cargo install` is idempotent: skips if already installed at the requested
# version. --locked uses the crate's Cargo.lock for reproducible builds.
#
# - cargo-insta: snapshot-test review TUI.
# - inferno:     flamegraph/flamechart renderer. Provides `inferno-flamegraph`
#                used by `trading-agents --trace-out` + `just trace-svg` to
#                render tracing-flame folded-stack output to SVG waterfalls.
need=(cargo-insta inferno)

for crate in "${need[@]}"; do
  if cargo install --list | grep -q "^${crate} v"; then
    echo "cargo-tools: ${crate} already installed"
  else
    echo "cargo-tools: installing ${crate}"
    cargo install --locked "${crate}"
  fi
done
