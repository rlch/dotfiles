# === Theme + visuals ===
theme         = "Catppuccin Mocha"
font-family   = "JetBrainsMono Nerd Font"
font-size     = 15
cursor-style       = bar
cursor-style-blink = false

# === Window chrome ===
macos-titlebar-style   = hidden
window-padding-x       = 6
window-padding-y       = 4
window-padding-balance = true
window-save-state      = always
background-blur        = macos-glass-regular

# === UX ===
mouse-hide-while-typing        = true
confirm-close-surface          = false
clipboard-trim-trailing-spaces = true

# Drop OSC 9 / OSC 777 desktop-notification escape sequences. Claude Code's
# `auto` notif channel, plus any other CLI tool that asks the terminal to
# pop a macOS banner, route through this — flipping it false short-circuits
# the lot at the terminal level. Tmux's bell only sets the in-status badge
# (@tab-transient in tmux.conf); it doesn't go through OSC 9, so the in-tmux
# "agent awaiting reply" glyph still works.
desktop-notifications = false

# === SSH terminfo propagation ===
# Defaults are: cursor,no-sudo,title,no-ssh-env,no-ssh-terminfo,path
# Opt into the two ssh-* features so remote hosts get correct TERM and a
# bundled xterm-ghostty terminfo (cached per host) — otherwise SSH targets
# without the entry render undercurl/italics/colors as garbage.
shell-integration-features = ssh-env,ssh-terminfo

# === Keybinds ===
# alt+backspace → delete word backwards. Without this, Option+Backspace sends
# nothing useful to TUI apps (Claude Code, bash, readline) — Ghostty's
# macos-option-as-alt is unset by default, so Option is a special-character
# modifier rather than Alt. Surgical bind so Option's other behaviors stay
# intact (no global macos-option-as-alt).
keybind = alt+backspace=text:\x1b\x7f

# ctrl+slash → emit CSI-u so tmux can distinguish it from ctrl+_. Ghostty's
# encoder silently drops this key by default (no byte emitted at all), so
# we manually send the CSI-u sequence via csi: (which builds ESC [ ... and
# doesn't depend on text-escape interpretation). 47 = '/' codepoint,
# 5 = ctrl modifier per CSI-u spec. Tmux with `extended-keys on` decodes
# this as C-/ and fires the session+window switcher (with preview).
keybind = ctrl+slash=csi:47;5u

# ctrl+space → emit CSI-u so tmux's prefix2=C-Space binding fires reliably.
# Legacy encoding maps Ctrl+Space to NUL (0x00) which tmux can match, but
# Ghostty's encoder is unreliable here (same family of bugs as ctrl+slash).
# 32 = ' ' codepoint, 5 = ctrl modifier.
keybind = ctrl+space=csi:32;5u

# ctrl+y → emit CSI-u so tmux's `bind C-y display-popup yazi` fires.
# Karabiner remaps the spotlight key (F4 / apple_vendor `spotlight` /
# `launchpad`) to ctrl+y inside Ghostty. The legacy Ctrl+Y byte (0x19) is
# the emacs/fish "yank" character — by upgrading to CSI-u via this
# keybind, tmux intercepts before fish and the yank shortcut is sacrificed
# only inside tmux. 121 = 'y' codepoint, 5 = ctrl modifier.
keybind = ctrl+y=csi:121;5u

# cmd+1..9 → emit CSI-u so tmux's `bind -T root C-1..9 select-window` fires
# (zellij GoToTab N). Tmux has no native cmd modifier, so we masquerade the
# keypress as ctrl+digit on the wire — Ghostty captures cmd+digit, sends
# CSI-u with codepoints 49..57 ('1'..'9') and modifier 5 (ctrl), and tmux
# reads it as C-N. The user-facing key is cmd; tmux never knows.
#
# Trigger spelling matters: Ghostty's default `super+digit_N=goto_tab:N`
# uses the physical-digit key code, distinct from the character keysym
# `super+N`. Spelling our override as `cmd+one` parses as `super+1`
# (character form) which leaves the goto_tab default *unshadowed*, and
# cmd+digit just switches Ghostty native tabs. Use `cmd+digit_N` to land
# on the same trigger as the default and properly override it.
keybind = cmd+digit_1=text:\x1b[49;5u
keybind = cmd+digit_2=text:\x1b[50;5u
keybind = cmd+digit_3=text:\x1b[51;5u
keybind = cmd+digit_4=text:\x1b[52;5u
keybind = cmd+digit_5=text:\x1b[53;5u
keybind = cmd+digit_6=text:\x1b[54;5u
keybind = cmd+digit_7=text:\x1b[55;5u
keybind = cmd+digit_8=text:\x1b[56;5u
keybind = cmd+digit_9=text:\x1b[57;5u

# cmd+shift+digit_N — jump to Nth session (alphabetical order). Same
# trick as cmd+digit_N above, but modifier 6 (ctrl+shift) instead of 5
# (ctrl), so tmux reads it as C-S-1..9 and the corresponding
# `bind -T root C-S-N run-shell tmux-switch-session.sh N` fires.
keybind = cmd+shift+digit_1=text:\x1b[49;6u
keybind = cmd+shift+digit_2=text:\x1b[50;6u
keybind = cmd+shift+digit_3=text:\x1b[51;6u
keybind = cmd+shift+digit_4=text:\x1b[52;6u
keybind = cmd+shift+digit_5=text:\x1b[53;6u
keybind = cmd+shift+digit_6=text:\x1b[54;6u
keybind = cmd+shift+digit_7=text:\x1b[55;6u
keybind = cmd+shift+digit_8=text:\x1b[56;6u
keybind = cmd+shift+digit_9=text:\x1b[57;6u

# ctrl+[ / ctrl+] — jump to prev/next window with Claude's "awaiting reply"
# bell (or any TUI hardware bell). ctrl+shift+[ / ctrl+shift+] do the same
# across all sessions. Sent as CSI-u so tmux can distinguish them — without
# this, ctrl+[ collapses to the ESC byte (0x1B) and shift on a non-letter
# key never reaches the wire. Codepoints: 91 = '[', 93 = ']'. Modifiers:
# 5 = ctrl, 6 = ctrl+shift. Tmux binds them as C-[ / C-] / C-S-[ / C-S-].
keybind = ctrl+bracket_left=csi:91;5u
keybind = ctrl+bracket_right=csi:93;5u
keybind = ctrl+shift+bracket_left=csi:91;6u
keybind = ctrl+shift+bracket_right=csi:93;6u
