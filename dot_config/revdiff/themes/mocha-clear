# name: mocha-clear
# description: catppuccin-mocha with transparent status bar / tree / diff
#              (lets ghostty's terminal background show through, matches tmux look)
# author: rlch (derived from upstream catppuccin-mocha)

chroma-style = catppuccin-mocha
color-accent = #89b4fa
color-border = #45475a
color-normal = #cdd6f4
color-muted = #7f849c
color-selected-fg = #1e1e2e
color-selected-bg = #89b4fa
color-annotation = #f9e2af
color-cursor-fg = #a6e3a1
# color-cursor-bg, color-tree-bg, color-diff-bg, color-status-bg intentionally
# omitted so revdiff falls back to "terminal default" (transparent) per
# https://github.com/umputun/revdiff#themes precedence rules.
color-add-fg = #a6e3a1
color-add-bg = #1a3a1a
color-remove-fg = #f38ba8
color-remove-bg = #4a1a1a
color-modify-fg = #fab387
color-modify-bg = #4a3a1a
color-status-fg = #cdd6f4
color-search-fg = #1e1e2e
color-search-bg = #f9e2af
